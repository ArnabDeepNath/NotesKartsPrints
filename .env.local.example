# ─── Copy this file to .env and fill in your values ───────────────────────────
# All variables in ONE file — used by both Next.js and Express (single process)

# Server
NODE_ENV=production
PORT=3000

# Database (Hostinger MySQL)
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex

# Your domain (no trailing slash)
CLIENT_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Next.js public API URL (same domain, /api prefix)
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Email (optional — for future notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
